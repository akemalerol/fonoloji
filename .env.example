# ─── Core ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# ─── Security (REQUIRED in production) ─────────────────────────────────
# 32+ character random strings. Generate with: openssl rand -hex 32
FONOLOJI_COOKIE_SECRET=change-me-to-a-long-random-string-32plus-chars
FONOLOJI_JWT_SECRET=change-me-to-a-different-long-random-string-32plus

# ─── Database ─────────────────────────────────────────────────────────
# Default: ./tefas.db (relative to repo root)
# FONOLOJI_DB_PATH=/var/lib/fonoloji/tefas.db

# ─── Site ─────────────────────────────────────────────────────────────
FONOLOJI_SITE_URL=https://fonoloji.com
FONOLOJI_MAIL_FROM="Fonoloji <no-reply@fonoloji.com>"
FONOLOJI_CONTACT_TO=admin@fonoloji.com
FONOLOJI_REPLY_TO=admin@fonoloji.com

# ─── TEFAS scraper ─────────────────────────────────────────────────────
# Requests per minute against TEFAS — keep conservative
FONOLOJI_RPM=30
# Optional HTTP proxy for large backfills
# FONOLOJI_PROXY_URL=http://user:pass@proxy:8080
# FONOLOJI_COOKIE_FILE=./tefas-cookies.json
# FONOLOJI_BENCHMARK_CODE=IPB
# FONOLOJI_CPI_YOY=0.38

# ─── External services (optional) ──────────────────────────────────────
# Transactional email (Resend)
# RESEND_API_KEY=re_xxx

# AI market digest / tweet generation (OpenAI)
# OPENAI_API_KEY=sk-xxx
# FONOLOJI_AI_MODEL=gpt-4o-mini

# X / Twitter integration (OAuth 1.0a user tokens)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────
# Set to 1 to disable all cron jobs (useful for dev / backfill runs)
# FONOLOJI_DISABLE_CRON=0
# FONOLOJI_PORTFOLIO_SKIP_RECENT=1
