{
  "name": "tefas-fund-scraper",
  "version": "1.0.0",
  "description": "Apify Actor — Turkish TEFAS investment fund data scraper (daily + historical).",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "api:dev": "npm run dev --workspace=@fonoloji/api",
    "api:ingest": "npm run ingest --workspace=@fonoloji/api",
    "web:dev": "npm run dev --workspace=@fonoloji/web",
    "dev": "concurrently -n api,web -c blue,magenta \"npm:api:dev\" \"npm:web:dev\""
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "apify": "^3.2.6",
    "cheerio": "^1.0.0",
    "got-scraping": "^4.1.1",
    "tough-cookie": "^4.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/tough-cookie": "^4.0.5",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
